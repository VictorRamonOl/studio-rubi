# Supabase — pegar em Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Chave SECRETA (sb_secret_...): SÓ no servidor. NUNCA expor no client/GitHub.
# Necessária para criar logins de paciente. Pegar em: Connect > Server, ou
# Project Settings > API Keys > secret.
SUPABASE_SECRET_KEY=sb_secret_...

# URL pública do app (usada em e-mails de recuperação de senha etc.)
NEXT_PUBLIC_APP_URL=https://app.rubistudiopilates.com.br

# Connection string do Postgres (Project Settings > Database > Connection string
# > URI). Só para aplicar migrations via CLI/psql. NÃO vai pro browser.
DATABASE_URL=postgresql://postgres:[SENHA]@db.xxxxxxxx.supabase.co:5432/postgres
